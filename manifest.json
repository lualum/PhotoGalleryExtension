{
  "manifest_version": 3,
  "name": "New Tab Photo Gallery",
  "description": "A new tab photo gallery with clock, date, battery info, and a local photo plane",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newpage.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "64": "icons/icon64.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "64": "icons/icon64.png"
    }
  }
}
